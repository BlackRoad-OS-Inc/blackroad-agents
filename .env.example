# BlackRoad Agents — Environment Configuration
# Copy to .env and fill in values

# ─── Gateway ───────────────────────────────────────────────────────────────
# URL of the blackroad-core tokenless gateway
# Agents NEVER hold provider API keys — all AI calls go through here
BLACKROAD_GATEWAY_URL=http://127.0.0.1:8787

# Gateway JWT secret (for agent authentication)
BLACKROAD_GATEWAY_SECRET=

# ─── Registry ──────────────────────────────────────────────────────────────
# Port for the agent registry HTTP API
REGISTRY_PORT=3001
REGISTRY_HOST=127.0.0.1

# SQLite database path
AGENT_DB_PATH=~/.blackroad/agent-registry.db

# ─── Fleet ─────────────────────────────────────────────────────────────────
# WireGuard mesh network (hub-and-spoke via shellfish, 10.8.0.0/24)
WIREGUARD_NETWORK=10.8.0.0/24
WIREGUARD_PORT=51820

# Node identity (set on each device)
AGENT_NODE_ID=
AGENT_NODE_IP=


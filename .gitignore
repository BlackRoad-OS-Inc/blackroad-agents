# BlackRoad OS - Security-First Gitignore

# Secrets & credentials (NEVER commit)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore
**/credentials.json
**/service-account*.json
**/.master.key
**/vault/.master.key

# API tokens & auth
.cloudflare-token
.railway-token
.vercel-token
.digitalocean-token
.anthropic-key
.openai-key

# Process files
*.pid
*.sock
*.lock
!package-lock.json
!pnpm-lock.yaml

# Runtime & build
logs/
node_modules/
__pycache__/
*.pyc
.next/
dist/
build/
.cache/
.turbo/
.vercel/

# OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/settings.json
.vscode/launch.json

# SQLite WAL/SHM (database files are OK, journals are temp)
*.db-wal
*.db-shm

# Test artifacts
coverage/
.nyc_output/
*.tsbuildinfo

# Wallet & seed files (NEVER commit)
**/seeds/
**/wallets/
*.wallet.dat
**/credentials.yaml

# Local-only settings
.claude/settings.local.json

# Temp / scratch files
*.save

# Registry treasury (local data)
registry/treasury/
